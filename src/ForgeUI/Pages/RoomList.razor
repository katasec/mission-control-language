@page "/rooms"
@attribute [Authorize]
@using ForgeMission.Rooms
@using ForgeMission.Rooms.Data
@inject IReadStore Reads
@inject CurrentUser Current
@inject StarterRoomService Starter
@inject NavigationManager Nav

<div class="page">
    <div class="page-header">
        <h2>Rooms</h2>
        <div class="header-actions">
            <a class="btn-link" href="/playground">Mission playground</a>
            <AccountMenu />
        </div>
    </div>

    @if (_me is null)
    {
        <p class="empty-state">Loading…</p>
    }
    else if (_rooms.Count == 0)
    {
        <p class="empty-state">You're not in any rooms yet. Ask a provisioner for an invite link.</p>
    }
    else
    {
        <ul class="room-list">
            @foreach (var room in _rooms)
            {
                <li class="room-list-item">
                    <a href="/rooms/@room.Id"><span class="room-list-name">@room.Metadata.Name</span></a>
                    @if (!string.IsNullOrEmpty(room.Metadata.Description))
                    {
                        <div class="room-list-desc">@room.Metadata.Description</div>
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    private Member? _me;
    private IReadOnlyList<Room> _rooms = [];

    private bool _onboardChecked;

    protected override async Task OnInitializedAsync()
    {
        _me = await Current.GetMemberAsync();
        if (_me is not null)
            _rooms = await Reads.GetRoomsForMemberAsync(_me.Id);
    }

    // Onboarding runs once on the interactive circuit (post-prerender), where both DB access and
    // NavigateTo are reliable. It re-reads rather than trusting _me/_rooms, because OnAfterRender
    // can fire before OnInitializedAsync's awaits complete, and a prerender NavigateTo after an
    // await does not redirect.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _onboardChecked)
            return;
        _onboardChecked = true;

        var me = await Current.GetMemberAsync();
        if (me is null)
            return;

        // Always run onboarding: it creates the starter room for a brand-new user AND self-heals
        // an existing solo room-of-two that's missing its agent (e.g. rooms provisioned before the
        // @forge/assistant member was seeded). Returns a new room id only when one was created.
        if (await Starter.EnsureStarterRoomAsync(me) is { } starterId)
            Nav.NavigateTo($"/rooms/{starterId}");
    }
}
