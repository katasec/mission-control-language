@page "/rooms"
@attribute [Authorize]
@using ForgeMission.Rooms
@using ForgeMission.Rooms.Data
@inject IReadStore Reads
@inject CurrentUser Current
@inject NavigationManager Nav

<div class="app-main" style="padding: 2rem; max-width: 640px;">
    <div style="display:flex; justify-content:space-between; align-items:baseline;">
        <h2>Rooms</h2>
        @if (_me is not null)
        {
            <span style="color:#888; font-size:0.85rem;">
                @_me.DisplayName (@_me.Email)
                <form action="/auth/logout" method="post" style="display:inline;">
                    <button class="show-thinking" type="submit" style="margin-left:0.5rem;">sign out</button>
                </form>
            </span>
        }
    </div>

    @if (_me is null)
    {
        <p>Loading…</p>
    }
    else if (_rooms.Count == 0)
    {
        <p>You're not in any rooms yet. Ask a provisioner for an invite link.</p>
    }
    else
    {
        <ul>
            @foreach (var room in _rooms)
            {
                <li style="margin: 0.5rem 0;">
                    <a href="/rooms/@room.Id">@room.Metadata.Name</a>
                    @if (!string.IsNullOrEmpty(room.Metadata.Description))
                    {
                        <span style="color: #888;"> — @room.Metadata.Description</span>
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    private Member? _me;
    private IReadOnlyList<Room> _rooms = [];

    protected override async Task OnInitializedAsync()
    {
        _me = await Current.GetMemberAsync();
        if (_me is not null)
            _rooms = await Reads.GetRoomsForMemberAsync(_me.Id);
    }
}
