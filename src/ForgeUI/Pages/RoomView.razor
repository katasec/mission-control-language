@page "/rooms/{RoomId:guid}"
@attribute [Authorize]
@using ForgeMission.Core.Runtime
@using ForgeMission.Rooms
@using ForgeMission.Rooms.Data
@inject IReadStore Reads
@inject CurrentUser Current
@inject RoomMessageService Messages
@inject RoomBroadcaster Broadcaster
@inject InviteService Invites
@inject NavigationManager Nav
@implements IDisposable

<div class="app-main" style="padding: 1.5rem; max-width: 720px; display: flex; flex-direction: column; height: 100vh;">
    @if (_me is null)
    {
        <p>Loading…</p>
    }
    else if (_denied)
    {
        <p>You are not a member of this room. <a href="/rooms">Back to rooms</a></p>
    }
    else
    {
        <div style="border-bottom: 1px solid #ddd; padding-bottom: 0.5rem;">
            <a href="/rooms">← rooms</a>
            <strong style="margin-left: 1rem;">@(_room?.Metadata.Name ?? "…")</strong>
            <span style="color: #888; margin-left: 1rem;">
                @string.Join(" · ", _memberNames.Values)
            </span>
            <span style="float: right; color: #888;">
                you: @_me.DisplayName@(_isProvisioner ? " (provisioner)" : "")
            </span>
        </div>

        @if (_isProvisioner)
        {
            <div style="padding: 0.4rem 0; font-size: 0.85rem;">
                <button class="show-thinking" @onclick="CreateInviteAsync">+ create invite link</button>
                @if (_inviteUrl is not null)
                {
                    <span style="margin-left: 0.5rem;">
                        <input readonly value="@_inviteUrl" style="width: 60%; font-size: 0.8rem;"
                               @onfocus="SelectAll" />
                    </span>
                }
            </div>
        }

        <div style="flex: 1; overflow-y: auto; padding: 1rem 0;">
            @foreach (var msg in _messages)
            {
                var mine = msg.SenderId == _me.Id;

                @if (msg.Trust is { } trust)
                {
                    <div style="margin: 0.6rem 0; text-align: left;">
                        <div class="agent-card @(trust.Verified ? "card-verified" : "card-unverified")">
                            <div class="agent-card-header">
                                <TrustSignalBadge Signal="ToSignal(trust)" />
                                <span class="mission-label">@msg.SenderName</span>
                                <span class="chat-meta">@msg.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                                @if (trust.Trace.Count > 0)
                                {
                                    <button class="show-thinking" @onclick="() => ToggleTrace(msg.Id)">
                                        @(_expanded.Contains(msg.Id) ? "hide thinking ▲" : "show thinking ▼")
                                    </button>
                                }
                            </div>
                            <div class="agent-answer">@msg.Text</div>
                            <PipelineTrace Events="ToEvents(trust)" ShowTrace="_expanded.Contains(msg.Id)" />
                        </div>
                    </div>
                }
                else
                {
                    var bg = mine ? "#d1e7ff" : "#eee";
                    <div style="margin: 0.4rem 0; text-align: @(mine ? "right" : "left");">
                        <div style="font-size: 0.75rem; color: #888;">
                            @msg.SenderName · @msg.CreatedAt.ToLocalTime().ToString("HH:mm:ss")
                        </div>
                        <span style="display: inline-block; padding: 0.4rem 0.7rem; border-radius: 0.6rem;
                                     background: @bg;">
                            @msg.Text
                        </span>
                    </div>
                }
            }

            @if (_thinkingHandle is not null)
            {
                <div style="margin: 0.4rem 0; text-align: left; color: #7e57c2; font-style: italic;">
                    @_thinkingHandle is thinking…
                </div>
            }
        </div>

        <div style="display: flex; gap: 0.5rem; padding-top: 0.5rem;">
            <input style="flex: 1; padding: 0.5rem;"
                   @bind="_input"
                   @bind:event="oninput"
                   @onkeydown="OnKeyDown"
                   placeholder="Message @(_room?.Metadata.Name)…" />
            <button @onclick="SendAsync" disabled="@string.IsNullOrWhiteSpace(_input)">Send</button>
        </div>
    }
</div>

@code {
    [Parameter] public Guid RoomId { get; set; }

    private Member? _me;
    private bool _isProvisioner;
    private Room? _room;
    private Dictionary<Guid, string> _memberNames = [];
    private readonly List<RoomMessageDto> _messages = [];
    private readonly HashSet<Guid> _expanded = [];
    private string _input = "";
    private bool _denied;
    private string? _thinkingHandle;
    private string? _inviteUrl;
    private IDisposable? _subscription;

    private void ToggleTrace(Guid messageId)
    {
        if (!_expanded.Remove(messageId))
            _expanded.Add(messageId);
    }

    // Reconstruct the Phase 35 view models from the DTO so the existing trust components
    // render unchanged (38.3). Verified is the guarded value from the mapping.
    private static TrustSignal ToSignal(AgentTrustDto trust)
        => new(trust.Verified, trust.StepCount, trust.RetryCount);

    private static List<PipelineTraceEvent> ToEvents(AgentTrustDto trust)
        => trust.Trace
            .Select(s => new PipelineTraceEvent(
                s.ExpertName,
                new StepEnvelope(s.Text ?? string.Empty, s.Status, s.Reason),
                DateTime.UtcNow,
                s.Attempt))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        _me = await Current.GetMemberAsync();
        if (_me is null)
            return;

        // Membership is the confidentiality boundary — a non-member gets nothing.
        var membership = await Reads.GetMembershipAsync(RoomId, _me.Id);
        if (membership is null)
        {
            _denied = true;
            return;
        }
        _isProvisioner = membership.Role == MembershipRole.Provisioner;

        _room = await Reads.GetRoomAsync(RoomId);
        _memberNames = (await Reads.GetRoomMembersAsync(RoomId)).ToDictionary(m => m.Id, m => m.DisplayName);

        foreach (var message in await Reads.GetRecentMessagesAsync(RoomId, limit: 50))
            _messages.Add(message.ToDto(_memberNames.GetValueOrDefault(message.SenderId, "unknown")));

        // Live delivery — subscribe in-process (this circuit is already authenticated).
        _subscription = Broadcaster.Subscribe(RoomId, OnRoomEvent);
    }

    private Task OnRoomEvent(RoomEvent evt)
    {
        switch (evt)
        {
            case MessagePosted posted:
                _messages.Add(posted.Message);
                if (posted.Message.SenderKind == "agent")
                    _thinkingHandle = null;
                break;
            case AgentThinking thinking:
                _thinkingHandle = thinking.Handle;
                break;
            case AgentFailed failed:
                _thinkingHandle = null;
                _messages.Add(new RoomMessageDto(
                    Guid.NewGuid(), RoomId, Guid.Empty, failed.Handle, "agent",
                    $"{failed.Handle} could not complete this request.", null, DateTimeOffset.UtcNow));
                break;
        }
        return InvokeAsync(StateHasChanged);
    }

    private async Task SendAsync()
    {
        if (_me is null || string.IsNullOrWhiteSpace(_input))
            return;
        var text = _input;
        _input = "";
        await Messages.SendHumanMessageAsync(RoomId, _me, text);
    }

    private Task OnKeyDown(KeyboardEventArgs e)
        => e.Key == "Enter" ? SendAsync() : Task.CompletedTask;

    private async Task CreateInviteAsync()
    {
        if (_me is null)
            return;
        var invite = await Invites.CreateAsync(RoomId, _me, MembershipRole.Consumer, ttl: TimeSpan.FromDays(7));
        _inviteUrl = Nav.ToAbsoluteUri($"/invite/{invite.Token}").ToString();
    }

    private static void SelectAll() { /* focus selects via readonly input; placeholder for JS-free UX */ }

    public void Dispose() => _subscription?.Dispose();
}
