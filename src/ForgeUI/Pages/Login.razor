@page "/login"
@using Microsoft.AspNetCore.Components.Authorization
@inject IConfiguration Config
@inject IHostEnvironment Env
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<div class="auth-shell">
    <div class="auth-card">
        <h2 class="auth-title">Sign in to Forge Rooms</h2>
        <p class="auth-sub">You're invited into rooms — sign in to see them.</p>

        @if (_oidcConfigured)
        {
            <a class="btn btn-primary auth-provider" href="@LoginUrl()">Sign in with Microsoft</a>
            <p class="auth-note">Google &amp; Apple sign-in appear on the hosted page.</p>
        }

        @if (Env.IsDevelopment())
        {
            <div class="auth-dev">
                <div class="auth-dev-label">Dev sign-in (local only)</div>
                <div class="auth-dev-list">
                    <a href="@DevUrl("alice")">Alice — provisioner of Demo Room</a>
                    <a href="@DevUrl("bob")">Bob — consumer in Demo Room</a>
                    <a href="@DevUrl("carol")">Carol — brand-new user (no rooms)</a>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool _oidcConfigured;
    private string? _returnUrl;

    protected override async Task OnInitializedAsync()
    {
        _oidcConfigured = !string.IsNullOrWhiteSpace(Config["Oidc:Authority"])
                          && !string.IsNullOrWhiteSpace(Config["Oidc:ClientId"]);

        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var q = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        _returnUrl = q.TryGetValue("returnUrl", out var r) ? r.ToString() : "/rooms";

        // Already signed in? Skip the page.
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            Nav.NavigateTo(_returnUrl!, forceLoad: false);
    }

    private string LoginUrl() => $"/auth/login?returnUrl={Uri.EscapeDataString(_returnUrl ?? "/rooms")}";
    private string DevUrl(string user) => $"/auth/dev?user={user}&returnUrl={Uri.EscapeDataString(_returnUrl ?? "/rooms")}";
}
