@using ForgeMission.Core.Runtime
@using ForgeMission.Rooms
@using ForgeMission.Rooms.Data
@inject IReadStore Reads
@inject CurrentUser Current
@inject RoomMessageService Messages
@inject RoomBroadcaster Broadcaster
@inject InviteService Invites
@inject AgentRegistry Agents
@inject RoomAgentMembershipService AgentMgmt
@inject RoomAdminService Admin
@inject NavigationManager Nav
@implements IDisposable

@* The conversation pane of the rooms shell. A pure component keyed on RoomId — the parent
   Pages/Rooms shell recreates it on room switch, so init/subscribe/dispose stay per-room. *@
<div class="convo">
    @if (_me is null)
    {
        <div class="convo-empty">Loading…</div>
    }
    else if (_denied)
    {
        <div class="convo-empty">
            <div class="convo-empty-title">You're not in this room.</div>
            <div>Ask a provisioner for an invite link.</div>
        </div>
    }
    else
    {
        <div class="convo-header">
            <a class="convo-back" href="/rooms" aria-label="Back to rooms"><Icon Name="back" /></a>
            <span class="convo-name">@(_room?.Metadata.Name ?? "…")</span>
            <button class="convo-members-btn" @onclick="OpenMembersAsync">@MemberCountLabel</button>
            @if (_isProvisioner)
            {
                <span class="room-badge">provisioner</span>
            }
        </div>

        <div class="room-stream">
            @if (_messages.Count == 0)
            {
                <div class="room-hint">
                    <div class="room-hint-title">This is the start of your conversation.</div>
                    @if (SoleAgentHandle is { } handle)
                    {
                        <div class="room-hint-sub">Send a message and <strong>@handle</strong> will reply — every answer is independently verified before you see it.</div>
                    }
                    <div class="room-hint-sub">Type <strong>/agents</strong> to see who you can address.</div>
                </div>
            }

            @foreach (var msg in _messages)
            {
                var mine = msg.SenderId == _me.Id;

                @if (msg.Trust is { } trust)
                {
                    var descriptor = DescriptorFor(msg.SenderName);
                    var verifies = descriptor?.VerifiesAnswers ?? true;
                    var cardClass = !verifies ? "card-raw" : (trust.Verified ? "card-verified" : "card-unverified");

                    <div class="room-msg room-msg-agent">
                        <div class="agent-card @cardClass">
                            <div class="agent-card-header">
                                <TrustSignalBadge Signal="ToSignal(trust)" Verifies="verifies" />
                                <span class="mission-label">@msg.SenderName</span>
                                <IdentitySealMark Descriptor="descriptor" />
                                <span class="chat-meta">@msg.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</span>
                                @if (trust.Trace.Count > 0)
                                {
                                    <button class="show-thinking" @onclick="() => ToggleTrace(msg.Id)">
                                        @(_expanded.Contains(msg.Id) ? "hide thinking ▲" : "show thinking ▼")
                                    </button>
                                }
                            </div>
                            <div class="agent-answer">@msg.Text</div>
                            <PipelineTrace Events="ToEvents(trust)" ShowTrace="_expanded.Contains(msg.Id)" />
                        </div>
                    </div>
                }
                else
                {
                    <div class="room-msg @(mine ? "room-msg-own" : "")">
                        <div class="msg-avatar">@Initial(msg.SenderName)</div>
                        <div class="msg-body">
                            <div class="msg-meta">
                                <span class="msg-sender">@msg.SenderName</span> · @msg.CreatedAt.ToLocalTime().ToString("HH:mm:ss")
                            </div>
                            <div class="msg-bubble @(mine ? "msg-bubble-own" : "")">@msg.Text</div>
                        </div>
                    </div>
                }
            }

            @if (_agentsListing is { } listing)
            {
                <div class="agents-directory">
                    <div class="agents-directory-head">
                        <span class="agents-directory-title">Agents you can address</span>
                        <button class="btn-link agents-directory-dismiss" @onclick="() => _agentsListing = null">dismiss</button>
                    </div>
                    @foreach (var a in listing)
                    {
                        <div class="agents-directory-row">
                            <div class="agents-directory-line">
                                <span class="agents-directory-handle">@a.Handle</span>
                                <IdentitySealMark Descriptor="a" />
                                <span class="agents-directory-publisher">@a.Publisher</span>
                            </div>
                            <div class="agents-directory-desc">@a.Description</div>
                        </div>
                    }
                </div>
            }

            @if (_thinkingHandle is not null)
            {
                <div class="agent-thinking">@_thinkingHandle @(_progressLabel ?? "is thinking…")</div>
            }
        </div>

        @if (_notice is not null)
        {
            <div class="room-notice">@_notice</div>
        }

        <div class="room-composer">
            @if (_mentionMatches.Count > 0)
            {
                <div class="mention-menu">
                    @foreach (var (handle, i) in _mentionMatches.Select((h, i) => (h, i)))
                    {
                        <button type="button"
                                class="mention-item @(i == _mentionIndex ? "mention-active" : "")"
                                @onclick="() => PickMentionAsync(handle)">
                            <span class="mention-avatar">@Initial(handle)</span>
                            <span class="mention-handle">@handle</span>
                            <IdentitySealMark Descriptor="DescriptorFor(handle)" />
                            <span class="mention-desc">@(DescriptorFor(handle)?.Description)</span>
                        </button>
                    }
                </div>
            }
            <input class="field room-input"
                   value="@_input"
                   @oninput="OnComposerInput"
                   @onkeydown="OnComposerKeyDown"
                   @ref="_inputRef"
                   placeholder="Message @(_room?.Metadata.Name)… (@@ to mention an agent)" />
            <button class="btn btn-primary" @onclick="SendAsync" disabled="@string.IsNullOrWhiteSpace(_input)">Send</button>
        </div>
    }
</div>

@* Members modal — the room's people + agents in one roster, with rename, add-agent and invite
   folded in (provisioner-gated). Opened from the header "N members" button or an absent-agent
   nudge. Floats over the conversation instead of pushing it down. *@
@if (_showMembers)
{
    <div class="modal-backdrop" @onclick="CloseMembers">
        <div class="modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true">
            <div class="modal-head">
                <span class="modal-title">Members</span>
                <button class="modal-close" @onclick="CloseMembers" aria-label="Close">✕</button>
            </div>
            <div class="modal-body">
                <div>
                    <label class="field-label">Room name</label>
                    @if (_isProvisioner)
                    {
                        <div class="modal-name-row">
                            <input class="field" value="@_renameValue" @oninput="OnRenameInput" @onkeydown="OnRenameKeyDown" />
                            <button class="btn btn-accent btn-sm" @onclick="SaveRenameAsync" disabled="@(!RenameDirty)">Save</button>
                        </div>
                    }
                    else
                    {
                        <div class="modal-name-static">@(_room?.Metadata.Name)</div>
                    }
                    @if (_room is not null)
                    {
                        <div class="modal-name-meta">Created @_room.CreatedAt.ToLocalTime().ToString("d MMM yyyy")</div>
                    }
                </div>

                <div>
                    <span class="manage-label">People</span>
                    @foreach (var p in RosterHumans())
                    {
                        <div class="member-row">
                            <span class="member-avatar">@Initial(p.Member.DisplayName)</span>
                            <span class="member-main">
                                <span class="member-name">@p.Member.DisplayName</span>
                                @if (_me is not null && p.Member.Id == _me.Id)
                                {
                                    <span class="member-you">you</span>
                                }
                            </span>
                            @if (p.Role == MembershipRole.Provisioner)
                            {
                                <span class="member-role">provisioner</span>
                            }
                        </div>
                    }
                </div>

                <div>
                    <span class="manage-label">Agents</span>
                    @if (!RosterAgents().Any())
                    {
                        <div class="manage-desc">No agents in this room yet.</div>
                    }
                    @foreach (var a in RosterAgents())
                    {
                        <div class="member-row">
                            <span class="member-agent-handle">@a.Member.DisplayName</span>
                            <IdentitySealMark Descriptor="DescriptorFor(a.Member.DisplayName)" />
                            <span class="flex-spacer"></span>
                            @if (_isProvisioner)
                            {
                                <button class="link-danger" @onclick="() => RemoveAgentAsync(a.Member.Id)">remove</button>
                            }
                        </div>
                    }
                </div>

                @if (_isProvisioner)
                {
                    <div>
                        <span class="manage-label">Add an agent</span>
                        @if (_addableAgents.Count == 0)
                        {
                            <div class="manage-desc">Every available agent is already in this room.</div>
                        }
                        else
                        {
                            <div class="agent-pick-list">
                                @foreach (var d in _addableAgents)
                                {
                                    <div class="agent-pick @(d.Handle == _pendingAddHandle ? "checked" : "")">
                                        <span class="agent-pick-handle">@d.Handle</span>
                                        <IdentitySealMark Descriptor="d" />
                                        <span class="agent-pick-desc">@d.Description</span>
                                        <button class="btn btn-accent btn-sm" @onclick="() => AddAgentAsync(d.Handle)">Add</button>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div>
                        <span class="manage-label">Invite people</span>
                        @if (_inviteUrl is null)
                        {
                            <button class="btn" @onclick="CreateInviteAsync">Create invite link</button>
                        }
                        else
                        {
                            <input class="field field-full" readonly value="@_inviteUrl" @onfocus="SelectAll" />
                            <div class="manage-desc">Anyone with this link can join (expires in 7 days).</div>
                        }
                    </div>
                }
            </div>
            <div class="modal-foot">
                <button class="btn btn-accent" @onclick="CloseMembers">Done</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid RoomId { get; set; }

    /// <summary>Raised when the room's name or membership changes, so the parent shell can refresh
    /// the sidebar (room name + member sublines) without a full reload.</summary>
    [Parameter] public EventCallback OnRoomChanged { get; set; }

    private Member? _me;
    private bool _isProvisioner;
    private Room? _room;
    private Dictionary<Guid, string> _memberNames = [];
    private readonly List<RoomMessageDto> _messages = [];
    private readonly HashSet<Guid> _expanded = [];
    private string _input = "";
    private bool _denied;
    private string? _thinkingHandle;
    // Transient step-progress label on the pending bubble (41.7) — e.g. "Searching the web…". Never
    // persisted; cleared when the answer (or failure) arrives.
    private string? _progressLabel;
    // Ephemeral /agents directory (38.5 task 9) — a personal, client-side lookup; never posted.
    private IReadOnlyList<AgentDescriptor>? _agentsListing;
    private string? _inviteUrl;
    private IDisposable? _subscription;
    // Members modal (roster + rename + add-agent + invite) and the "not in this room" nudge.
    private bool _showMembers;
    private IReadOnlyList<RoomMemberInfo> _roster = [];
    private IReadOnlyList<AgentDescriptor> _addableAgents = [];
    private string? _pendingAddHandle;
    private string _renameValue = "";
    private string? _notice;

    // Header affordance: "N members" — the click target that opens the roster modal.
    private string MemberCountLabel => _memberNames.Count == 1 ? "1 member" : $"{_memberNames.Count} members";

    // The rename Save button is live only when the name actually changed and isn't blank.
    private bool RenameDirty
        => !string.IsNullOrWhiteSpace(_renameValue)
           && !string.Equals(_renameValue.Trim(), _room?.Metadata.Name, StringComparison.Ordinal);

    // Roster split — people first, agents second, each alphabetical (WhatsApp-style grouping).
    private IEnumerable<RoomMemberInfo> RosterHumans()
        => _roster.Where(r => r.Member.Kind == MemberKind.Human).OrderBy(r => r.Member.DisplayName, StringComparer.OrdinalIgnoreCase);

    private IEnumerable<RoomMemberInfo> RosterAgents()
        => _roster.Where(r => r.Member.Kind == MemberKind.Agent).OrderBy(r => r.Member.DisplayName, StringComparer.OrdinalIgnoreCase);
    // @-mention autocomplete (38.5 task 2).
    private ElementReference _inputRef;
    private string? _mentionQuery;
    private List<string> _mentionMatches = [];
    private int _mentionIndex;

    private void ToggleTrace(Guid messageId)
    {
        if (!_expanded.Remove(messageId))
            _expanded.Add(messageId);
    }

    // First letter of a sender's name, for the avatar circle.
    private static string Initial(string name)
        => string.IsNullOrWhiteSpace(name) ? "?" : name.TrimStart()[..1].ToUpperInvariant();

    // Agent members use @handle display names; surface the sole one for the empty-state hint.
    private string? SoleAgentHandle
        => _memberNames.Values.FirstOrDefault(n => n.StartsWith('@'));

    // Resolve a sender handle to its registry descriptor for the identity seal (38.5 task 8a).
    // Agent message SenderName is the member DisplayName == the bare handle; non-agents/unknown
    // handles resolve to null and render no seal.
    private AgentDescriptor? DescriptorFor(string handle)
        => Agents.TryResolveDescriptor(handle, out var d) ? d : null;

    // Reconstruct the Phase 35 view models from the DTO so the existing trust components
    // render unchanged (38.3). Verified is the guarded value from the mapping.
    private static TrustSignal ToSignal(AgentTrustDto trust)
        => new(trust.Verified, trust.StepCount, trust.RetryCount);

    private static List<PipelineTraceEvent> ToEvents(AgentTrustDto trust)
        => trust.Trace
            .Select(s => new PipelineTraceEvent(
                s.ExpertName,
                new StepEnvelope(s.Text ?? string.Empty, s.Status, s.Reason),
                DateTime.UtcNow,
                s.Attempt))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        _me = await Current.GetMemberAsync();
        if (_me is null)
            return;

        // Membership is the confidentiality boundary — a non-member gets nothing.
        var membership = await Reads.GetMembershipAsync(RoomId, _me.Id);
        if (membership is null)
        {
            _denied = true;
            return;
        }
        _isProvisioner = membership.Role == MembershipRole.Provisioner;

        _room = await Reads.GetRoomAsync(RoomId);
        _memberNames = (await Reads.GetRoomMembersAsync(RoomId)).ToDictionary(m => m.Id, m => m.DisplayName);

        foreach (var message in await Reads.GetRecentMessagesAsync(RoomId, limit: 50))
            _messages.Add(message.ToDto(_memberNames.GetValueOrDefault(message.SenderId, "unknown")));

        // Live delivery — subscribe in-process (this circuit is already authenticated).
        _subscription = Broadcaster.Subscribe(RoomId, OnRoomEvent);
    }

    private Task OnRoomEvent(RoomEvent evt)
    {
        switch (evt)
        {
            case MessagePosted posted:
                _messages.Add(posted.Message);
                if (posted.Message.SenderKind == "agent")
                {
                    _thinkingHandle = null;
                    _progressLabel = null;
                }
                break;
            case AgentThinking thinking:
                _thinkingHandle = thinking.Handle;
                _progressLabel = null;   // reset to the default "is thinking…" until progress flows
                break;
            case AgentProgress progress:
                _thinkingHandle = progress.Handle;
                _progressLabel = progress.Label;
                break;
            case AgentFailed failed:
                _thinkingHandle = null;
                _progressLabel = null;
                _messages.Add(new RoomMessageDto(
                    Guid.NewGuid(), RoomId, Guid.Empty, failed.Handle, "agent",
                    $"{failed.Handle} could not complete this request.", null, DateTimeOffset.UtcNow));
                break;
        }
        return InvokeAsync(StateHasChanged);
    }

    private async Task SendAsync()
    {
        if (_me is null || string.IsNullOrWhiteSpace(_input))
            return;
        var text = _input.Trim();

        // Slash commands are handled client-side and never posted to the room (38.5 task 9).
        // /agents is a personal discovery lookup — ephemeral, only the caller sees it, not
        // persisted or broadcast. Scoped to what the addressing user can consume (built-ins today).
        if (string.Equals(text, "/agents", StringComparison.OrdinalIgnoreCase))
        {
            _agentsListing = Agents.List();
            _input = "";
            ClearMentions();
            return;
        }

        // Addressing a known agent that isn't a member of this room (38.5 task 3): don't post a
        // lonely message the auto-reply would swallow — tell the user, and if they can provision,
        // open the manage-agents modal pre-pointed at that agent.
        if (AddressedAbsentAgent(text) is { } absent)
        {
            _notice = _isProvisioner
                ? $"{absent.Handle} isn't in this room yet — add it below, then message it."
                : $"{absent.Handle} isn't in this room. Ask a provisioner to add it.";
            _input = "";
            ClearMentions();
            if (_isProvisioner)
            {
                _pendingAddHandle = absent.Handle;
                await OpenMembersAsync();
            }
            return;
        }

        _agentsListing = null;   // a real message dismisses the ephemeral listing
        _notice = null;
        _input = "";
        ClearMentions();
        await Messages.SendHumanMessageAsync(RoomId, _me, text);
    }

    // A registry agent whose handle appears in the text but which is NOT a member of this room.
    private AgentDescriptor? AddressedAbsentAgent(string text)
    {
        var present = _memberNames.Values.ToHashSet(StringComparer.OrdinalIgnoreCase);
        return Agents.List().FirstOrDefault(d =>
            !present.Contains(d.Handle) &&
            text.Contains(d.Handle, StringComparison.OrdinalIgnoreCase));
    }

    // Open the members modal: load the roster + addable agents, seed the rename box with the
    // current name. Leaves _pendingAddHandle untouched so an absent-agent nudge can pre-point it.
    private async Task OpenMembersAsync()
    {
        _renameValue = _room?.Metadata.Name ?? "";
        await RefreshRosterAsync();
        _showMembers = true;
    }

    private void CloseMembers()
    {
        _showMembers = false;
        _pendingAddHandle = null;
    }

    private async Task RefreshRosterAsync()
    {
        _roster = await Reads.GetRoomRosterAsync(RoomId);
        _addableAgents = await AgentMgmt.AddableAgentsAsync(RoomId);
    }

    private async Task RemoveAgentAsync(Guid agentMemberId)
    {
        if (_me is null) return;
        await AgentMgmt.RemoveAgentAsync(RoomId, _me, agentMemberId);
        await RefreshMembersAsync();
    }

    private async Task AddAgentAsync(string handle)
    {
        if (_me is null) return;
        await AgentMgmt.AddAgentAsync(RoomId, _me, handle);
        _pendingAddHandle = null;
        _notice = null;
        await RefreshMembersAsync();
    }

    // Reload everything membership drives — the header count, mention list, and modal roster —
    // then nudge the parent shell to refresh the sidebar sublines.
    private async Task RefreshMembersAsync()
    {
        _memberNames = (await Reads.GetRoomMembersAsync(RoomId)).ToDictionary(m => m.Id, m => m.DisplayName);
        await RefreshRosterAsync();
        StateHasChanged();
        await OnRoomChanged.InvokeAsync();
    }

    // --- Rename (provisioner-only) -------------------------------------------------------------

    private void OnRenameInput(ChangeEventArgs e)
        => _renameValue = e.Value?.ToString() ?? "";

    private async Task OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && RenameDirty)
            await SaveRenameAsync();
    }

    private async Task SaveRenameAsync()
    {
        if (_me is null || _room is null || !RenameDirty)
            return;
        var name = _renameValue.Trim();
        if (!await Admin.RenameAsync(RoomId, _me, name))
            return;
        _room.Metadata.Name = name;   // reflect in the header + composer placeholder immediately
        await OnRoomChanged.InvokeAsync();
    }

    // --- @-mention autocomplete (38.5 task 2) -------------------------------------------------

    private void OnComposerInput(ChangeEventArgs e)
    {
        _input = e.Value?.ToString() ?? string.Empty;
        RecomputeMentions();
    }

    // Show the picker when the caret sits inside an "@token" (start-of-word @, no whitespace after),
    // filtered to the room's addressable agents — matching what you can actually @-invoke here.
    private void RecomputeMentions()
    {
        _mentionQuery = ActiveMentionQuery(_input);
        if (_mentionQuery is null)
        {
            _mentionMatches = [];
            _mentionIndex = 0;
            return;
        }

        var q = _mentionQuery;
        _mentionMatches = RoomAgentHandles()
            .Where(h => q.Length == 0
                        || h[1..].StartsWith(q, StringComparison.OrdinalIgnoreCase)
                        || h[1..].Contains(q, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(h => h[1..].StartsWith(q, StringComparison.OrdinalIgnoreCase))
            .ThenBy(h => h, StringComparer.OrdinalIgnoreCase)
            .Take(6)
            .ToList();
        _mentionIndex = 0;
    }

    // The @-handles addressable in this room = the room's agent members.
    private IEnumerable<string> RoomAgentHandles()
        => _memberNames.Values.Where(v => v.StartsWith('@'));

    // The text after the active, word-starting '@' up to the caret (== end of input), or null.
    private static string? ActiveMentionQuery(string input)
    {
        if (string.IsNullOrEmpty(input)) return null;
        var at = input.LastIndexOf('@');
        if (at < 0) return null;
        if (at > 0 && !char.IsWhiteSpace(input[at - 1])) return null; // must start a word
        var token = input[(at + 1)..];
        return token.Any(char.IsWhiteSpace) ? null : token;
    }

    private async Task PickMentionAsync(string handle)
    {
        var at = _input.LastIndexOf('@');
        _input = (at >= 0 ? _input[..at] : _input) + handle + " ";
        ClearMentions();
        await _inputRef.FocusAsync();
    }

    private void ClearMentions()
    {
        _mentionMatches = [];
        _mentionQuery = null;
        _mentionIndex = 0;
    }

    private async Task OnComposerKeyDown(KeyboardEventArgs e)
    {
        if (_mentionMatches.Count > 0)
        {
            switch (e.Key)
            {
                case "ArrowDown":
                    _mentionIndex = (_mentionIndex + 1) % _mentionMatches.Count;
                    return;
                case "ArrowUp":
                    _mentionIndex = (_mentionIndex - 1 + _mentionMatches.Count) % _mentionMatches.Count;
                    return;
                case "Enter":
                    await PickMentionAsync(_mentionMatches[_mentionIndex]);
                    return;
                case "Escape":
                    ClearMentions();
                    return;
            }
        }

        if (e.Key == "Enter")
            await SendAsync();
    }

    private async Task CreateInviteAsync()
    {
        if (_me is null)
            return;
        var invite = await Invites.CreateAsync(RoomId, _me, MembershipRole.Consumer, ttl: TimeSpan.FromDays(7));
        _inviteUrl = Nav.ToAbsoluteUri($"/invite/{invite.Token}").ToString();
    }

    private static void SelectAll() { /* focus selects via readonly input; placeholder for JS-free UX */ }

    public void Dispose() => _subscription?.Dispose();
}
