// Text Quality Pipeline — Phase 22b Spoke 6 demo
//
// Proves the full LLM -> json_extract -> onnx -> LLM pipeline end-to-end.
//
// SETUP: Before running, generate the ONNX model:
//   pip install scikit-learn skl2onnx
//   python generate_model.py
// This produces models/quality-scorer.onnx which QualityScorer requires.
//
// USAGE:
//   forge run --mission TextQuality --input "Your text here"

let text = "The quick brown fox jumps over the lazy dog. This sentence is often used to test typefaces. It contains every letter of the alphabet."

mission TextQuality(text) = {
    FeatureExtractor
    -> ExtractFeatures
    -> QualityScorer
    -> Explainer
}

output(TextQuality)
